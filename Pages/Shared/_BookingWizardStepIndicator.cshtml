@* Booking Wizard Step Indicator - pass CurrentStep (1-4) as ViewData["CurrentStep"] *@
@{
    var currentStep = (int)(ViewData["CurrentStep"] ?? 1);
}
<div class="d-flex justify-content-center mb-4">
    <div class="d-flex align-items-center">
        @for (int i = 1; i <= 4; i++)
        {
            var stepNames = new[] { "", "Guest", "Function", "Payment", "Follow-up" };
            var isActive = i == currentStep;
            var isCompleted = i < currentStep;
            var badgeClass = isActive ? "bg-primary" : (isCompleted ? "bg-success" : "bg-secondary");
            
            <div class="text-center mx-2">
                <span class="badge rounded-pill @badgeClass p-2" style="width: 30px; height: 30px; line-height: 16px;">@i</span>
                <div class="small mt-1 @(isActive ? "fw-bold" : "")">@stepNames[i]</div>
            </div>
            if (i < 4)
            {
                <div class="border-top @(isCompleted ? "border-success" : "border-secondary")" style="width: 40px; margin-top: -10px;"></div>
            }
        }
    </div>
</div>

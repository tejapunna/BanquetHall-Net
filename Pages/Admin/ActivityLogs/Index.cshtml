@page
@model BanquetHall.Pages.Admin.ActivityLogs.IndexModel
@{
    ViewData["Title"] = "Activity Logs";
    Layout = "~/Pages/Shared/_AdminLayout.cshtml";
}

<h2>Activity Logs</h2>

<form method="get" class="row g-3 mb-4">
    <div class="col-12 col-md-3">
        <label asp-for="UserId" class="form-label">User</label>
        <select asp-for="UserId" class="form-select">
            <option value="">-- All Users --</option>
            @foreach (var user in Model.Users)
            {
                <option value="@user.Id">@user.FullName (@user.Username)</option>
            }
        </select>
    </div>
    <div class="col-12 col-md-3">
        <label asp-for="ActionType" class="form-label">Action Type</label>
        <select asp-for="ActionType" class="form-select">
            <option value="">-- All --</option>
            <option value="Create">Create</option>
            <option value="Update">Update</option>
            <option value="Transfer">Transfer</option>
        </select>
    </div>
    <div class="col-12 col-md-3">
        <label asp-for="EntityType" class="form-label">Entity Type</label>
        <select asp-for="EntityType" class="form-select">
            <option value="">-- All --</option>
            <option value="Guest">Guest</option>
            <option value="GuestFunction">GuestFunction</option>
            <option value="Payment">Payment</option>
            <option value="FollowUp">FollowUp</option>
        </select>
    </div>
    <div class="col-12 col-md-3 d-flex align-items-end">
        <button type="submit" class="btn btn-primary">Filter</button>
    </div>
</form>

@if (Model.Logs.Any())
{
    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead>
                <tr>
                    <th>Timestamp</th>
                    <th>Username</th>
                    <th>Action Type</th>
                    <th>Entity Type</th>
                    <th>Entity ID</th>
                    <th>Details</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var log in Model.Logs)
                {
                    <tr>
                        <td>@log.Timestamp.ToString("dd-MMM-yyyy HH:mm:ss")</td>
                        <td>@log.Username</td>
                        <td>@log.ActionType</td>
                        <td>@log.EntityType</td>
                        <td>@log.EntityId</td>
                        <td>@log.Details</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
else
{
    <div class="alert alert-info">No activity logs found matching the filters.</div>
}

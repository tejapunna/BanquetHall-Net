@page
@model BanquetHall.Pages.Admin.Leads.IndexModel
@{
    Layout = "~/Pages/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "All Leads";
}

<h3 class="mb-3">All Leads</h3>

<!-- Filters -->
<div class="card mb-4">
    <div class="card-body">
        <form method="get" class="row g-3 align-items-end">
            <div class="col-12 col-md-2">
                <label class="form-label">Lead Date From</label>
                <input type="date" name="LeadDateFrom" class="form-control" value="@Model.LeadDateFrom?.ToString("yyyy-MM-dd")" />
            </div>
            <div class="col-12 col-md-2">
                <label class="form-label">Lead Date To</label>
                <input type="date" name="LeadDateTo" class="form-control" value="@Model.LeadDateTo?.ToString("yyyy-MM-dd")" />
            </div>
            <div class="col-12 col-md-2">
                <label class="form-label">Function Date From</label>
                <input type="date" name="FunctionDateFrom" class="form-control" value="@Model.FunctionDateFrom?.ToString("yyyy-MM-dd")" />
            </div>
            <div class="col-12 col-md-2">
                <label class="form-label">Function Date To</label>
                <input type="date" name="FunctionDateTo" class="form-control" value="@Model.FunctionDateTo?.ToString("yyyy-MM-dd")" />
            </div>
            <div class="col-12 col-md-2">
                <label class="form-label">Manager</label>
                <select name="ManagerId" class="form-select">
                    <option value="">All</option>
                    @foreach (var mgr in Model.Managers)
                    {
                        <option value="@mgr.Id" selected="@(Model.ManagerId == mgr.Id)">@mgr.FullName</option>
                    }
                </select>
            </div>
            <div class="col-12 col-md-2">
                <button type="submit" class="btn btn-primary w-100">Filter</button>
            </div>
        </form>
    </div>
</div>

<!-- Leads Table -->
<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-striped table-hover mb-0">
                <thead>
                    <tr>
                        <th>Lead Date</th>
                        <th>Function Date</th>
                        <th>Name</th>
                        <th>Phone</th>
                        <th>Status</th>
                        <th>Managed By</th>
                        <th>Last Follow-Up</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Leads.Any())
                    {
                        @foreach (var lead in Model.Leads)
                        {
                            <tr>
                                <td>@lead.LeadDate.ToString("dd-MMM-yyyy")</td>
                                <td>@(lead.FunctionDate?.ToString("dd-MMM-yyyy") ?? "-")</td>
                                <td><a asp-page="/Admin/Leads/Details" asp-route-id="@lead.GuestId" class="text-decoration-none text-purple fw-semibold">@lead.Name</a></td>
                                <td>@lead.Phone</td>
                                <td><span class="badge bg-info">@lead.Status</span></td>
                                <td>@lead.ManagedBy</td>
                                <td>@(lead.LastFollowUpDate?.ToString("dd-MMM-yyyy") ?? "-")</td>
                                <td>
                                    <a asp-page="/Admin/Leads/Details" asp-route-id="@lead.GuestId" class="btn btn-sm btn-outline-primary">View</a>
                                    <button onclick="printLead(@lead.GuestId)" class="btn btn-sm btn-outline-secondary">Print</button>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="8" class="text-center text-muted py-4">No leads found.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>


@section Scripts {
<script>
function printLead(guestId) {
    window.open('/Admin/Leads/Details/' + guestId, '_blank');
}
</script>
}

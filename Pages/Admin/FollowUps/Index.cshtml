@page
@model BanquetHall.Pages.Admin.FollowUps.IndexModel
@{
    Layout = "~/Pages/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "All Follow-Ups";
}

<h3 class="mb-4">All Follow-Ups</h3>

<form method="get" class="row mb-4 g-2">
    <div class="col-12 col-md-3">
        <label class="form-label">Manager</label>
        <select asp-for="ManagerId" class="form-select">
            <option value="">All Managers</option>
            @foreach (var m in Model.Managers)
            {
                <option value="@m.Id">@m.FullName</option>
            }
        </select>
    </div>
    <div class="col-12 col-md-3">
        <label class="form-label">Status</label>
        <select asp-for="StatusFilter" class="form-select">
            <option value="">All Statuses</option>
            <option value="New">New</option>
            <option value="In Progress">In Progress</option>
            <option value="Followup">Followup</option>
        </select>
    </div>
    <div class="col-12 col-md-3">
        <label class="form-label">Follow-Up Status</label>
        <select asp-for="FollowupStatusFilter" class="form-select">
            <option value="">All</option>
            <option value="May Close">May Close</option>
            <option value="May Not Close">May Not Close</option>
            <option value="Success">Success</option>
            <option value="Failed">Failed</option>
        </select>
    </div>
    <div class="col-12 col-md-3 d-flex align-items-end gap-2">
        <button type="submit" class="btn btn-primary">Filter</button>
        <a asp-page="/Admin/FollowUps/Index" class="btn btn-outline-secondary">Clear</a>
    </div>
</form>

@if (Model.FollowUps.Any())
{
    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>Guest Name</th>
                    <th>Manager</th>
                    <th>Status</th>
                    <th>Follow-Up Status</th>
                    <th>Date</th>
                    <th>Remarks</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var fu in Model.FollowUps)
                {
                    <tr>
                        <td>@(fu.Guest?.Name ?? "-")</td>
                        <td>@(fu.Manager?.FullName ?? "-")</td>
                        <td><span class="badge bg-secondary">@fu.Status</span></td>
                        <td><span class="badge bg-info">@fu.FollowupStatus</span></td>
                        <td>@fu.FollowupDate.ToString("dd-MMM-yyyy")</td>
                        <td>@(fu.Remarks ?? "-")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
else
{
    <div class="alert alert-info">No follow-ups found matching the criteria.</div>
}

@page
@model BanquetHall.Pages.Admin.Bookings.IndexModel
@{
    Layout = "~/Pages/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "All Bookings";
}

<h3 class="mb-4">All Bookings</h3>

<form method="get" class="row mb-4 g-2">
    <div class="col-12 col-md-3">
        <label class="form-label">Manager</label>
        <select asp-for="ManagerFilter" class="form-select">
            <option value="">All Managers</option>
            @foreach (var m in Model.Managers)
            {
                <option value="@m.FullName">@m.FullName</option>
            }
        </select>
    </div>
    <div class="col-12 col-md-3">
        <label class="form-label">From Date</label>
        <input asp-for="FromDate" type="date" class="form-control" />
    </div>
    <div class="col-12 col-md-3">
        <label class="form-label">To Date</label>
        <input asp-for="ToDate" type="date" class="form-control" />
    </div>
    <div class="col-12 col-md-3 d-flex align-items-end gap-2">
        <button type="submit" class="btn btn-primary">Filter</button>
        <a asp-page="/Admin/Bookings/Index" class="btn btn-outline-secondary">Clear</a>
    </div>
</form>

@if (Model.Bookings.Any())
{
    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>Guest Name</th>
                    <th>Function Type</th>
                    <th>Function Date</th>
                    <th>Meal Plan</th>
                    <th>Address</th>
                    <th>Initiated By</th>
                    <th>Created</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var b in Model.Bookings)
                {
                    <tr>
                        <td>@(b.Guest?.Name ?? "-")</td>
                        <td>@b.FunctionType</td>
                        <td>@b.FunctionDate.ToString("dd-MMM-yyyy")</td>
                        <td>@b.MealPlan</td>
                        <td>@(b.GuestAddress ?? "-")</td>
                        <td>@(b.InitiatedBy ?? "-")</td>
                        <td>@b.CreatedAt.ToString("dd-MMM-yyyy")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
else
{
    <div class="alert alert-info">No bookings found matching the criteria.</div>
}

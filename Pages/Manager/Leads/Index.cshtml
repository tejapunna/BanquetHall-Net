@page
@model BanquetHall.Pages.Manager.Leads.IndexModel
@{
    Layout = "~/Pages/Shared/_ManagerLayout.cshtml";
    ViewData["Title"] = "My Leads";
}

<h3 class="mb-3">My Leads</h3>

<div class="card mb-4">
    <div class="card-body">
        <form method="get" class="row g-3 align-items-end" id="filterForm">
            <div class="col-12 col-md-3">
                <label class="form-label">Filter By</label>
                <select name="DateType" id="dateTypeFilter" class="form-select">
                    <option value="LeadDate" selected="@(Model.DateType == "LeadDate" || Model.DateType == null)">Lead Date</option>
                    <option value="FunctionDate" selected="@(Model.DateType == "FunctionDate")">Function Date</option>
                </select>
            </div>
            <div class="col-12 col-md-3">
                <label class="form-label">From Date</label>
                <input type="date" name="FromDate" class="form-control text-uppercase" value="@Model.FromDate?.ToString("yyyy-MM-dd")" style="text-transform: uppercase;" />
            </div>
            <div class="col-12 col-md-3">
                <label class="form-label">To Date</label>
                <input type="date" name="ToDate" class="form-control text-uppercase" value="@Model.ToDate?.ToString("yyyy-MM-dd")" style="text-transform: uppercase;" />
            </div>
            <div class="col-12 col-md-3 d-flex gap-2">
                <button type="submit" class="btn btn-primary">Filter</button>
                <a asp-page="/Manager/Leads/Index" class="btn btn-outline-secondary">Clear</a>
            </div>
        </form>
    </div>
</div>

<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-striped table-hover mb-0">
                <thead>
                    <tr>
                        <th>Lead Date</th>
                        <th>Function Date</th>
                        <th>Name</th>
                        <th>Phone</th>
                        <th>Status</th>
                        <th>Last Follow-Up</th>
                        <th>Next Follow-Up</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Leads.Any())
                    {
                        @foreach (var lead in Model.Leads)
                        {
                            var badgeClass = lead.Status switch
                            {
                                "Success" => "bg-success",
                                "Failed" => "bg-danger",
                                "May Close" => "bg-info",
                                "May Not Close" => "bg-warning text-dark",
                                "New" => "bg-secondary",
                                _ => "bg-secondary"
                            };
                            <tr>
                                <td>@lead.LeadDate.ToString("dd-MMM-yyyy")</td>
                                <td>@(lead.FunctionDate?.ToString("dd-MMM-yyyy") ?? "-")</td>
                                <td><a asp-page="/Manager/Leads/Details" asp-route-id="@lead.GuestId" class="text-decoration-none text-purple fw-semibold">@lead.Name</a></td>
                                <td>@lead.Phone</td>
                                <td><span class="badge @badgeClass">@lead.Status</span></td>
                                <td>@(lead.LastFollowUpDate?.ToString("dd-MMM-yyyy") ?? "-")</td>
                                <td>@(lead.NextFollowUpDate?.ToString("dd-MMM-yyyy") ?? "-")</td>
                                <td>
                                    <a asp-page="/Manager/Leads/Details" asp-route-id="@lead.GuestId" class="btn btn-sm btn-outline-primary">View</a>
                                    <a asp-page="/Manager/Leads/Edit" asp-route-id="@lead.GuestId" class="btn btn-sm btn-outline-secondary">Edit</a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr><td colspan="8" class="text-center text-muted py-4">No leads found.</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

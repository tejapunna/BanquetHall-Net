@page "{id:int}"
@model BanquetHall.Pages.Manager.Payments.CancelModel
@{
    Layout = "~/Pages/Shared/_ManagerLayout.cshtml";
    ViewData["Title"] = "Cancel Booking";
}

<h3 class="mb-4">Cancel Booking & Process Refund</h3>

@if (!string.IsNullOrEmpty(Model.SuccessMessage))
{
    <div class="alert alert-success">
        @Model.SuccessMessage
        <div class="mt-2">
            <a asp-page="/Manager/Payments/Index" class="btn btn-sm btn-outline-success">Back to Payments</a>
        </div>
    </div>
}
@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="alert alert-danger">@Model.ErrorMessage</div>
}

@if (Model.PaymentRecord != null && string.IsNullOrEmpty(Model.SuccessMessage))
{
    <div class="card mb-4">
        <div class="card-header bg-danger text-white">Booking Details</div>
        <div class="card-body">
            <div class="row">
                <div class="col-12 col-md-6 mb-2">
                    <strong>Guest:</strong> @(Model.PaymentRecord.Guest?.Name ?? "-")
                </div>
                <div class="col-12 col-md-6 mb-2">
                    <strong>Function:</strong> @(Model.PaymentRecord.Function?.FunctionType ?? "-") - @(Model.PaymentRecord.Function?.FunctionDate.ToString("dd-MMM-yyyy") ?? "-")
                </div>
                <div class="col-12 col-md-4 mb-2">
                    <strong>Total Amount:</strong> ₹@Model.PaymentRecord.Amount.ToString("N2")
                </div>
                <div class="col-12 col-md-4 mb-2">
                    <strong>Advance Paid:</strong> ₹@Model.PaymentRecord.AdvanceAmount.ToString("N2")
                </div>
                <div class="col-12 col-md-4 mb-2">
                    <strong>Remaining:</strong> ₹@Model.PaymentRecord.RemainingAmount.ToString("N2")
                </div>
            </div>
        </div>
    </div>

    <div class="card">
        <div class="card-header">Cancellation & Refund</div>
        <div class="card-body">
            <div class="alert alert-warning">
                <strong>Warning:</strong> This will cancel the booking and mark the follow-up as "Failed". This action cannot be undone.
            </div>
            <form method="post" asp-route-id="@Model.PaymentRecord.Id">
                <div class="row">
                    <div class="col-12 col-md-6 mb-3">
                        <label class="form-label">Refund Amount <span class="text-danger">*</span></label>
                        <input asp-for="RefundAmount" type="number" step="0.01" min="0" max="@Model.PaymentRecord.AdvanceAmount" class="form-control" />
                        <small class="text-muted">Maximum refundable: ₹@Model.PaymentRecord.AdvanceAmount.ToString("N2")</small>
                    </div>
                    <div class="col-12 col-md-6 mb-3">
                        <label class="form-label">Cancellation Reason <span class="text-danger">*</span></label>
                        <select asp-for="CancellationReason" class="form-select" required>
                            <option value="">-- Select Reason --</option>
                            <option value="Guest requested cancellation">Guest requested cancellation</option>
                            <option value="Date conflict">Date conflict</option>
                            <option value="Venue unavailable">Venue unavailable</option>
                            <option value="Payment dispute">Payment dispute</option>
                            <option value="Other">Other</option>
                        </select>
                    </div>
                </div>
                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-danger" onclick="return confirm('Are you sure you want to cancel this booking? This cannot be undone.')">Confirm Cancellation</button>
                    <a asp-page="/Manager/Payments/Index" class="btn btn-secondary">Go Back</a>
                </div>
            </form>
        </div>
    </div>
}

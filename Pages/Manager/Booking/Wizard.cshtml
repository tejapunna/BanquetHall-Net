@page
@model BanquetHall.Pages.Manager.Booking.WizardModel
@{
    var userRole = User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value;
    if (userRole == "Receptionist")
    {
        Layout = "~/Pages/Shared/_ReceptionistLayout.cshtml";
    }
    else
    {
        Layout = "~/Pages/Shared/_ManagerLayout.cshtml";
    }
    ViewData["Title"] = "New Lead";
}

<!-- <h3 class="mb-3">New Lead</h3> -->

@Html.AntiForgeryToken()

@* Guest Search - Smart Autofill *@
<partial name="_GuestSearchPartial" />

@* Step Indicator *@
<div id="stepIndicator">
    <div class="d-flex justify-content-center mb-4">
        <div class="d-flex align-items-center">
            <div class="text-center mx-2">
                <span class="badge rounded-pill bg-primary p-2 step-badge" data-step="1" style="width: 30px; height: 30px; line-height: 16px;">1</span>
                <div class="small mt-1 fw-bold step-label" data-step="1">Guest Info</div>
            </div>
            <div class="border-top border-secondary step-connector" data-after="1" style="width: 40px; margin-top: -10px;"></div>
            <div class="text-center mx-2">
                <span class="badge rounded-pill bg-secondary p-2 step-badge" data-step="2" style="width: 30px; height: 30px; line-height: 16px;">2</span>
                <div class="small mt-1 step-label" data-step="2">Function</div>
            </div>
            <div class="border-top border-secondary step-connector" data-after="2" style="width: 40px; margin-top: -10px;"></div>
            <div class="text-center mx-2">
                <span class="badge rounded-pill bg-secondary p-2 step-badge" data-step="3" style="width: 30px; height: 30px; line-height: 16px;">3</span>
                <div class="small mt-1 step-label" data-step="3">Summary</div>
            </div>
        </div>
    </div>
</div>

@* Step 1: Guest Info *@
<div id="step1" class="wizard-step">
    <div class="card">
        <div class="card-header bg-primary text-white">
            <h5 class="mb-0">Step 1: Guest Information</h5>
        </div>
        <div class="card-body">
            <form id="guestForm">
                <div class="row">
                    <div class="col-12 col-md-6 mb-3">
                        <label class="form-label">First Name <span class="text-danger">*</span></label>
                        <input type="text" id="guestFirstName" name="FirstName" class="form-control" required />
                        <div class="invalid-feedback"></div>
                    </div>
                    <div class="col-12 col-md-6 mb-3">
                        <label class="form-label">Last Name <span class="text-danger">*</span></label>
                        <input type="text" id="guestLastName" name="LastName" class="form-control" required />
                        <div class="invalid-feedback"></div>
                    </div>
                </div>
                <div class="row">
                    <div class="col-12 col-md-6 mb-3">
                        <label class="form-label">Mobile <span class="text-danger">*</span></label>
                        <input type="text" id="guestMobile" name="Mobile" class="form-control" required />
                        <div class="invalid-feedback"></div>
                    </div>
                    <div class="col-12 col-md-6 mb-3">
                        <label class="form-label">Email</label>
                        <input type="email" id="guestEmail" name="Email" class="form-control" />
                        <div class="invalid-feedback"></div>
                    </div>
                </div>
                <div class="row">
                    <div class="col-12 col-md-6 mb-3">
                        <label class="form-label">Village</label>
                        <input type="text" id="guestVillage" name="Village" class="form-control" />
                        <div class="invalid-feedback"></div>
                    </div>
                    <div class="col-12 col-md-6 mb-3">
                        <label class="form-label">Mandal</label>
                        <input type="text" id="guestMandal" name="Mandal" class="form-control" />
                        <div class="invalid-feedback"></div>
                    </div>
                </div>
                <div class="row">
                    <div class="col-12 col-md-6 mb-3">
                        <label class="form-label">Referred By Name</label>
                        <input type="text" id="guestReferredByName" name="ReferredByName" class="form-control" />
                        <div class="invalid-feedback"></div>
                    </div>
                    <div class="col-12 col-md-6 mb-3">
                        <label class="form-label">Referred By Phone</label>
                        <input type="text" id="guestReferredByPhone" name="ReferredByPhone" class="form-control" />
                        <div class="invalid-feedback"></div>
                    </div>
                </div>
                <div class="row">
                    <div class="col-12 col-md-6 mb-3">
                        <label class="form-label">Aadhaar Number</label>
                        <input type="text" id="guestAadhaar" name="GuestAadhaar" class="form-control" maxlength="12" />
                        <div class="invalid-feedback"></div>
                    </div>
                    <div class="col-12 col-md-6 mb-3">
                        <label class="form-label">PAN Number</label>
                        <input type="text" id="guestPan" name="GuestPan" class="form-control" maxlength="10" />
                        <div class="invalid-feedback"></div>
                    </div>
                </div>
                <div class="mb-3">
                    <label class="form-label">Remarks</label>
                    <textarea id="guestRemarks" name="Remarks" class="form-control" rows="2"></textarea>
                    <div class="invalid-feedback"></div>
                </div>
                <div class="d-flex justify-content-end">
                    <button type="submit" class="btn btn-primary">Next: Function Details &rarr;</button>
                </div>
            </form>
        </div>
    </div>
</div>

@* Step 2: Function Details *@
<div id="step2" class="wizard-step" style="display: none;">
    <div class="card">
        <div class="card-header bg-primary text-white">
            <h5 class="mb-0">Step 2: Function Details</h5>
        </div>
        <div class="card-body">
            <form id="functionForm">
                <div class="row">
                    <div class="col-12 col-md-6 mb-3">
                        <label class="form-label">Function Date <span class="text-danger">*</span></label>
                        <input type="date" id="functionDate" name="FunctionDate" class="form-control" required />
                        <div class="invalid-feedback"></div>
                    </div>
                    <div class="col-12 col-md-6 mb-3">
                        <label class="form-label">Function Name <span class="text-danger">*</span></label>
                        <select id="functionNameId" name="FunctionNameId" class="form-select" required>
                            <option value="">-- Loading... --</option>
                        </select>
                        <div class="invalid-feedback"></div>
                    </div>
                </div>
                <div class="row">
                    <div class="col-12 col-md-6 mb-3">
                        <label class="form-label">Meal Type <span class="text-danger">*</span></label>
                        <div class="mt-1">
                            <div class="form-check form-check-inline">
                                <input class="form-check-input" type="radio" name="MealType" id="mealTypeVeg" value="Veg" required />
                                <label class="form-check-label" for="mealTypeVeg">Veg</label>
                            </div>
                            <div class="form-check form-check-inline">
                                <input class="form-check-input" type="radio" name="MealType" id="mealTypeNonVeg" value="Non-Veg" />
                                <label class="form-check-label" for="mealTypeNonVeg">Non-Veg</label>
                            </div>
                        </div>
                        <div class="invalid-feedback"></div>
                    </div>
                    <div class="col-12 col-md-6 mb-3">
                        <label class="form-label">Meal Plan <span class="text-danger">*</span></label>
                        <select id="mealPlan" name="MealPlan" class="form-select" required>
                            <option value="">-- Select --</option>
                            <option value="Breakfast">Breakfast</option>
                            <option value="Lunch">Lunch</option>
                            <option value="Dinner">Dinner</option>
                            <option value="HiTea">Hi-Tea</option>
                        </select>
                        <div class="invalid-feedback"></div>
                    </div>
                </div>
                <div class="row">
                    <div class="col-12 col-md-6 mb-3">
                        <label class="form-label">No. of Packs</label>
                        <input type="number" id="noOfPacks" name="NoOfPacks" class="form-control" min="0" value="0" />
                        <div class="invalid-feedback"></div>
                    </div>
                    <div class="col-12 col-md-6 mb-3">
                        <label class="form-label">Guaranteed Packs</label>
                        <input type="number" id="guaranteedPacks" name="GuaranteedPacks" class="form-control" min="0" value="0" />
                        <div class="invalid-feedback"></div>
                    </div>
                </div>
                <div class="row">
                    <div class="col-12 col-md-6 mb-3">
                        <label class="form-label">Assigned Manager <span class="text-danger">*</span></label>
                        <select id="assignedManagerId" name="AssignedManagerId" class="form-select" required>
                            <option value="">-- Loading... --</option>
                        </select>
                        <div class="invalid-feedback"></div>
                    </div>
                    <div class="col-12 col-md-6 mb-3">
                        <label class="form-label">Function Hall <span class="text-danger">*</span></label>
                        <select id="functionHallId" name="FunctionHallId" class="form-select" required>
                            <option value="">-- Loading... --</option>
                        </select>
                        <div class="invalid-feedback"></div>
                    </div>
                </div>
                <div class="mb-3">
                    <label class="form-label">Special Instructions</label>
                    <textarea id="specialInstruction" name="SpecialInstruction" class="form-control" rows="2"></textarea>
                    <div class="invalid-feedback"></div>
                </div>
                <div class="d-flex justify-content-between">
                    <button type="button" class="btn btn-secondary btn-back" data-target="1">&larr; Back: Guest Info</button>
                    <button type="submit" class="btn btn-primary">Next: Summary &rarr;</button>
                </div>
            </form>
        </div>
    </div>
</div>

@* Step 3: Summary *@
<div id="step3" class="wizard-step" style="display: none;">
    <div class="card border-success">
        <div class="card-header bg-success text-white">
            <h5 class="mb-0"><i class="bi bi-check-circle"></i> Lead Created Successfully!</h5>
        </div>
        <div class="card-body">
            <div id="leadSummary"></div>
            <div class="mt-3 d-flex gap-2">
                <button type="button" class="btn btn-outline-primary" id="btnPrintSummary">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-printer me-1" viewBox="0 0 16 16"><path d="M2.5 8a.5.5 0 1 0 0-1 .5.5 0 0 0 0 1"/><path d="M5 1a2 2 0 0 0-2 2v2H2a2 2 0 0 0-2 2v3a2 2 0 0 0 2 2h1v1a2 2 0 0 0 2 2h6a2 2 0 0 0 2-2v-1h1a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-1V3a2 2 0 0 0-2-2zM4 3a1 1 0 0 1 1-1h6a1 1 0 0 1 1 1v2H4zm1 10a1 1 0 0 1-1-1v-2h8v2a1 1 0 0 1-1 1z"/></svg>
                    Print
                </button>
                <a href="/Manager/Booking/Wizard" class="btn btn-primary">New Lead</a>
                <a href="/Manager" class="btn btn-outline-secondary">Back to Dashboard</a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/smart-autofill.js"></script>
    <script src="~/js/booking-wizard.js"></script>
}
